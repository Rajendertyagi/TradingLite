<Window x:Class="TradingBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TradingBrowser.ViewModels"
        Title="TradingBrowser" Height="800" Width="1200"
        Background="#202124"
        WindowStyle="None" AllowsTransparency="False" ResizeMode="CanResize"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown"
        MouseMove="MainWindow_MouseMove"
        FontFamily="Segoe UI"> <!-- Clean Windows Font for UI -->

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MaxHeight="34"/>
            <RowDefinition Height="Auto" MaxHeight="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Tab Strip -->
        <Border x:Name="TabStripBorder" Grid.Row="0" Height="34" Background="#202124" MouseLeftButtonDown="TabStrip_MouseLeftButtonDown"
                Visibility="{Binding IsChartMode, Converter={StaticResource BoolVis}, ConverterParameter=Invert}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="TabBorder" Background="#292a2d" Margin="4,4,0,0" CornerRadius="8,8,0,0" MaxWidth="240" Height="30" VerticalAlignment="Bottom" 
                                        Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                                        MouseLeftButtonDown="Tab_Click" PreviewMouseLeftButtonDown="Tab_PreviewMouseLeftButtonDown"
                                        MouseMove="Tab_MouseMove" DragOver="Tab_DragOver" Drop="Tab_Drop" AllowDrop="True">
                                    <Border.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}" Background="#292a2d" Foreground="#e8eaed" FontSize="12">
                                            <MenuItem Header="Reload" Command="{Binding ReloadCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Background="#292a2d" Foreground="#e8eaed"/>
                                            <MenuItem Header="Duplicate" Command="{Binding DuplicateTabCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Background="#292a2d" Foreground="#e8eaed"/>
                                            <Separator/><MenuItem Header="Pin tab" Command="{Binding PinTabCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Background="#292a2d" Foreground="#e8eaed"/>
                                            <Separator/>
                                            <MenuItem Header="Screenshot tab" Command="{Binding ScreenshotCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Background="#292a2d" Foreground="#e8eaed"/>
                                            <MenuItem Header="Pop-out chart" Command="{Binding PopOutCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Background="#292a2d" Foreground="#e8eaed"/>
                                            <Separator/>
                                            <MenuItem Header="Close other tabs" Command="{Binding CloseOtherTabsCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Background="#292a2d" Foreground="#e8eaed"/>
                                            <MenuItem Header="Close tabs to the right" Command="{Binding CloseRightTabsCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Background="#292a2d" Foreground="#e8eaed"/>
                                            <Separator/><MenuItem Header="Close" Command="{Binding CloseTabCommand}" CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" Background="#292a2d" Foreground="#e8eaed"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Source="{Binding Favicon}" Margin="8,0,0,0" Width="16" Height="16" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TabText" Grid.Column="1" Text="{Binding Title}" Margin="6,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="#e8eaed" FontSize="12"/>
                                        <!-- FIX: Pure White Close Button -->
                                        <Button x:Name="CloseBtn" Grid.Column="2" Content="✕" FontSize="11" Width="16" Height="16" Margin="4,0,6,0" VerticalAlignment="Center"
                                                Foreground="White" Style="{StaticResource CaptionButtonStyle}" Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsPinned}" Value="True"><Setter TargetName="TabBorder" Property="MaxWidth" Value="40"/><Setter TargetName="TabText" Property="Visibility" Value="Collapsed"/><Setter TargetName="CloseBtn" Property="Visibility" Value="Collapsed"/></DataTrigger>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True"><Setter TargetName="TabBorder" Property="Background" Value="#35363A"/></DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <Button Content="+" Width="28" Height="28" Margin="4,0,0,0" FontWeight="Normal" Foreground="#9aa0a6" FontSize="16" Style="{StaticResource CaptionButtonStyle}" Command="{Binding AddTabCommand}" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="─" Width="46" Height="34" Foreground="#9aa0a6" FontSize="10" Style="{StaticResource CaptionButtonStyle}" Click="Minimize_Click"/>
                    <Button Content="☐" Width="46" Height="34" Foreground="#9aa0a6" FontSize="10" Style="{StaticResource CaptionButtonStyle}" Click="Maximize_Click"/>
                    <Button Content="✕" Width="46" Height="34" Foreground="#e8eaed" FontSize="10" Style="{StaticResource CloseButtonStyle}" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Address Bar -->
        <Border x:Name="AddressBarBorder" Grid.Row="1" Height="40" Background="#202124" Padding="8,0,8,0"
                Visibility="{Binding IsChartMode, Converter={StaticResource BoolVis}, ConverterParameter=Invert}">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,6,0" VerticalAlignment="Center">
                    <Button Content="←" Width="28" Height="28" Foreground="#9aa0a6" FontSize="14" Style="{StaticResource CaptionButtonStyle}" Click="Back_Click"/>
                    <Button Content="→" Width="28" Height="28" Foreground="#9aa0a6" FontSize="14" Style="{StaticResource CaptionButtonStyle}" Click="Forward_Click"/>
                    <Button x:Name="ReloadBtn" Content="↻" Width="28" Height="28" Foreground="#9aa0a6" FontSize="13" Style="{StaticResource CaptionButtonStyle}" Click="Reload_Click"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#35363A" CornerRadius="24" Height="32" VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="{Binding ShieldIcon}" FontSize="14" Margin="8,0,0,0" Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding ToggleShieldCommand}" VerticalAlignment="Center" ToolTip="Toggle Ad-Blocker for this site"/>
                        <TextBox x:Name="AddressBox" Grid.Column="1" Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" Margin="6,0,10,0" Background="Transparent" BorderThickness="0" Foreground="#e8eaed" FontSize="14" CaretBrush="#e8eaed" KeyDown="AddressBox_KeyDown"/>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0" VerticalAlignment="Center">
                    <Button Content="Fullscreen" Width="28" Height="28" Foreground="#9aa0a6" FontSize="14" Style="{StaticResource CaptionButtonStyle}" Command="{Binding ToggleChartModeCommand}" ToolTip="Chart Mode (F11)"/>
                    <Button Content="⚙️" Width="28" Height="28" Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding OpenSettingsCommand}" ToolTip="Settings"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" x:Name="ActiveWebViewHost" Background="#202124"/>

        <!-- 4. Download Manager Shelf -->
        <Border Grid.Row="3" Background="#292a2d" BorderThickness="0,1,0,0" BorderBrush="#3c4043" Padding="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Downloads.Count}" Value="0"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                        <DataTrigger Binding="{Binding Downloads.Count}" Value="1"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ItemsControl ItemsSource="{Binding Downloads}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#35363A" CornerRadius="4" Padding="8" Margin="0,4,0,4" Height="40">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <ProgressBar Height="4" Margin="0,4,0,0" Foreground="#8ab4f8" Background="#202124" Minimum="0" Maximum="100" Value="{Binding Progress}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <Button Content="Open" FontSize="11" Margin="0,0,5,0" Style="{StaticResource CaptionButtonStyle}" Foreground="#8ab4f8" Command="{Binding OpenFileCommand}" Visibility="{Binding IsComplete, Converter={StaticResource BoolVis}}"/>
                                    <Button Content="Folder" FontSize="11" Style="{StaticResource CaptionButtonStyle}" Foreground="#9aa0a6" Command="{Binding OpenFolderCommand}" Visibility="{Binding IsComplete, Converter={StaticResource BoolVis}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
