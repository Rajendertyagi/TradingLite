<Window x:Class="TradingBrowser.Views.FloatingChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pop-out Chart" Height="450" Width="600"
        Background="Black" WindowStyle="None" AllowsTransparency="False"
        Topmost="True" ShowInTaskbar="False" WindowStartupLocation="Manual"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#1E1E1E" MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="📊 Always on Top" Foreground="#888" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Button Content="✕" HorizontalAlignment="Right" Width="20" Height="20" Background="Transparent" Foreground="White" BorderThickness="0" Click="Close_Click"/>
            </Grid>
        </Border>
        <Grid Grid.Row="1" x:Name="FloatingHost"/>
    </Grid>
</Window>
